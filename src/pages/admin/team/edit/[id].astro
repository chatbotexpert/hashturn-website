---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { readJSON } from '../../../../utils/data';

interface TeamMember {
  id: string;
  name: string;
  role: string;
  bio: string;
  avatar: string;
  avatarColor: string;
  image: string;
  linkedin: string;
  order: number;
}

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/team');

const teams = await readJSON<TeamMember[]>('teams.json').catch(() => [] as TeamMember[]);
const member = teams.find(t => t.id === id);
if (!member) return Astro.redirect('/admin/team');
---

<AdminLayout title={`Edit: ${member.name}`} activeNav="team">
  <div class="admin-card">
    <div class="admin-card__header">
      <span class="admin-card__title">Edit Team Member</span>
      <a href="/admin/team" class="btn-admin btn-admin--outline">← Back</a>
    </div>

    <form method="POST" action="/admin/api/team" enctype="multipart/form-data" style="padding:1.5rem; display:flex; flex-direction:column; gap:1.25rem;">
      <input type="hidden" name="_action" value="update" />
      <input type="hidden" name="id" value={member.id} />
      <input type="hidden" name="order" value={member.order} />
      <input type="hidden" name="currentImage" value={member.image ?? ''} />

      <div class="form-row">
        <div class="form-group">
          <label for="name">Full Name *</label>
          <input type="text" id="name" name="name" required value={member.name} />
        </div>
        <div class="form-group">
          <label for="role">Role / Title *</label>
          <input type="text" id="role" name="role" required value={member.role} />
        </div>
      </div>

      <div class="form-group">
        <label for="bio">Bio</label>
        <textarea id="bio" name="bio" rows="3">{member.bio}</textarea>
      </div>

      <div class="form-group">
        <label for="linkedin">LinkedIn URL</label>
        <input type="url" id="linkedin" name="linkedin" value={member.linkedin ?? ''} placeholder="https://linkedin.com/in/username" />
      </div>

      <div class="form-group">
        <label for="image">Photo</label>
        {member.image && (
          <img src={member.image} alt={member.name} style="width:96px; height:96px; border-radius:50%; object-fit:cover; margin-bottom:0.5rem;" />
        )}
        <input type="file" id="image" name="image" accept="image/*" onchange="previewImage(this, 'imgPreview')" />
        <img id="imgPreview" src="" alt="Preview" style="display:none; margin-top:0.5rem; width:96px; height:96px; border-radius:50%; object-fit:cover;" />
        <span style="font-size:0.75rem; color:rgba(0,0,0,0.4);">{member.image ? 'Upload a new photo to replace the current one' : 'Optional — JPG, PNG, WebP'}</span>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="avatar">Initials / Avatar Text</label>
          <input type="text" id="avatar" name="avatar" maxlength="2" value={member.avatar} />
        </div>
        <div class="form-group">
          <label for="avatarColor">Avatar Color</label>
          <div style="display:flex; align-items:center; gap:0.75rem;">
            <input type="color" id="avatarColor" name="avatarColor" value={member.avatarColor} style="width:48px; height:40px; padding:2px; cursor:pointer;" />
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
              {['#22C55E', '#3B82F6', '#EF4444', '#EAB308', '#8B5CF6', '#EC4899', '#F97316'].map(c => (
                <button type="button" onclick={`document.getElementById('avatarColor').value='${c}'`}
                  style={`width:24px; height:24px; border-radius:50%; background:${c}; border:2px solid rgba(255,255,255,0.2); cursor:pointer;`}></button>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div style="display:flex; gap:1rem;">
        <button type="submit" class="btn-admin btn-admin--green">Save Changes</button>
        <a href="/admin/team" class="btn-admin btn-admin--outline">Cancel</a>
      </div>
    </form>
  </div>
</AdminLayout>

<style>
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
  @media (max-width:640px) { .form-row { grid-template-columns:1fr; } }
  .form-group { display:flex; flex-direction:column; gap:0.4rem; }
  label { font-size:0.8rem; font-weight:600; color:#374151; text-transform:uppercase; letter-spacing:0.04em; }
  input[type="text"], input[type="url"], textarea {
    background:#fff; border:1.5px solid #D1D5DB; border-radius:8px; padding:0.75rem 1rem;
    color:#111827; font-family:inherit; font-size:0.9rem; outline:none;
    transition:border-color 0.15s, box-shadow 0.15s; width:100%;
  }
  textarea { resize:vertical; }
  input:focus, textarea:focus { border-color:#22C55E; box-shadow:0 0 0 3px rgba(34,197,94,0.1); }
  input[type="file"] {
    background:#fff; border:1.5px dashed #D1D5DB; border-radius:8px; padding:0.6rem 1rem;
    color:#111827; font-family:inherit; font-size:0.875rem; cursor:pointer; width:100%;
  }
  input[type="file"]:hover { border-color:#22C55E; }
</style>

<script>
  function previewImage(input: HTMLInputElement, previewId: string) {
    const preview = document.getElementById(previewId) as HTMLImageElement | null;
    if (!preview) return;
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = (e) => {
        const result = (e.target as FileReader).result as string;
        preview.src = result;
        preview.style.display = 'block';
      };
      reader.readAsDataURL(input.files[0]);
    }
  }
</script>
