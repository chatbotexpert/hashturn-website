---
import Layout from '../layouts/Layout.astro';

// Turnstile site key — set your key from dash.cloudflare.com/turnstile
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA'; // demo key (always passes)
---

<Layout
  title="Contact HashTurn — Book a Free Strategy Call"
  description="Book a free 30-minute strategy call with HashTurn. Tell us about your business and we'll show you exactly how automation can save you time and money."
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="section-label">Get in Touch</p>
      <h1>Book Your Free<br /><span style="color:var(--green)">Strategy Call</span></h1>
      <p class="page-hero__sub">
        Tell us about your business and the tasks that are eating your team's time.
        We'll show you exactly how automation can fix it — for free.
      </p>
    </div>
  </section>

  <!-- Calendly Inline -->
  <section class="section section--gray" style="padding:3rem 1.5rem;">
    <div class="container text-center" style="margin-bottom:1rem;">
      <p class="section-label">Schedule Instantly</p>
      <h2 class="section-title" style="margin-bottom:0.5rem;">Book a Time That Works for You</h2>
      <p class="section-sub" style="margin:0 auto;">Pick a slot and we'll call you — no waiting, no back-and-forth.</p>
    </div>
    <div
      class="calendly-inline-widget"
      data-url="https://calendly.com/hashturns/30min"
      style="min-width:320px; height:700px; max-width:900px; margin:0 auto;"
    ></div>
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>
  </section>

  <!-- Contact Section -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <!-- Form -->
        <div class="contact-form-wrap">
          <h2 style="font-size:1.4rem; margin-bottom:0.5rem;">Send Us a Message</h2>
          <p style="color:var(--gray-500); font-size:0.9rem; margin-bottom:2rem;">
            Fill out the form below and we'll get back to you within 24 hours.
          </p>

          <form class="contact-form" id="contact-form" novalidate>
            <!-- honeypot: bots fill this, humans leave it blank -->
            <input type="text" name="_honey" style="display:none;" tabindex="-1" autocomplete="off" />
            <div class="form-row">
              <div class="form-group">
                <label for="name">Your Name <span class="req">*</span></label>
                <input type="text" id="name" name="name" placeholder="John Smith" required />
              </div>
              <div class="form-group">
                <label for="email">Email Address <span class="req">*</span></label>
                <input type="email" id="email" name="email" placeholder="john@company.com" required />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="company">Company Name</label>
                <input type="text" id="company" name="company" placeholder="Acme Corp" />
              </div>
              <div class="form-group">
                <label for="budget">Estimated Budget</label>
                <select id="budget" name="budget">
                  <option value="">Select a range</option>
                  <option value="under-500">Under $500</option>
                  <option value="500-2000">$500 – $2,000</option>
                  <option value="2000-5000">$2,000 – $5,000</option>
                  <option value="5000-plus">$5,000+</option>
                  <option value="not-sure">Not sure yet</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="service">What service are you interested in? <span class="req">*</span></label>
              <select id="service" name="service" required>
                <option value="">Select a service</option>
                <option value="bpa">Business Process Automation</option>
                <option value="rpa">Robotic Process Automation (RPA)</option>
                <option value="api">API &amp; Webhook Integration</option>
                <option value="crm">CRM Automation</option>
                <option value="microsoft">Microsoft 365 Solutions</option>
                <option value="dev">Mobile &amp; Web Development</option>
                <option value="other">Other / Not Sure</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Tell Us About Your Project <span class="req">*</span></label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Describe the tasks you want automated, the apps you use, and any challenges you're facing..."
                required
              ></textarea>
            </div>

            <div class="form-group">
              <label for="how">How did you find us?</label>
              <select id="how" name="how">
                <option value="">Select one</option>
                <option value="google">Google Search</option>
                <option value="fiverr">Fiverr</option>
                <option value="linkedin">LinkedIn</option>
                <option value="referral">Referral from someone</option>
                <option value="social">Social Media</option>
                <option value="other">Other</option>
              </select>
            </div>

            <input type="hidden" name="source" value="contact" />

            <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light"></div>

            <button type="submit" class="btn btn--green btn--lg" style="width:100%; justify-content:center;">
              Send Message &amp; Book Free Call
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>

            <p class="form-note">
              &#128274; Your information is private and will never be shared. We respond within 24 hours.
            </p>
          </form>

          <div class="form-success" id="form-success" style="display:none;">
            <div class="success-icon">&#10003;</div>
            <h3>Message Sent!</h3>
            <p>Thank you for reaching out. We'll get back to you within 24 hours to schedule your free strategy call.</p>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="contact-sidebar">
          <div class="sidebar-card">
            <h3>What Happens Next?</h3>
            <ol class="next-steps">
              <li>
                <div class="step-num-sm">1</div>
                <div>
                  <strong>We review your message</strong>
                  <p>Within 24 hours, our team reads your project details carefully.</p>
                </div>
              </li>
              <li>
                <div class="step-num-sm">2</div>
                <div>
                  <strong>Free strategy call</strong>
                  <p>We schedule a 30-minute call to discuss your needs and ask questions.</p>
                </div>
              </li>
              <li>
                <div class="step-num-sm">3</div>
                <div>
                  <strong>Custom proposal</strong>
                  <p>You receive a clear plan with timeline, deliverables, and fixed pricing.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="sidebar-card sidebar-card--dark">
            <h3 style="color:var(--white);">Why Work With Us?</h3>
            <ul class="sidebar-benefits">
              <li>&#11088; 5-star rated on Fiverr (200+ reviews)</li>
              <li>&#9989; 200+ automation projects delivered</li>
              <li>&#9889; Most projects start within 48 hours</li>
              <li>&#128176; Fixed pricing — no hidden fees</li>
              <li>&#127760; Serving clients worldwide</li>
            </ul>
          </div>

          <div class="sidebar-card">
            <h3>Prefer Email?</h3>
            <p style="font-size:0.9rem; color:var(--gray-500); margin-bottom:1rem;">
              You can also reach us directly at:
            </p>
            <a href="mailto:hello@hashturn.com" class="email-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              hello@hashturn.com
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cloudflare Turnstile script -->
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = btn.innerHTML;
    btn.innerHTML = 'Sending...';
    btn.disabled = true;

    try {
      const data = new FormData(form);
      const res = await fetch('/api/submit', { method: 'POST', body: data });
      if (res.ok) {
        form.style.display = 'none';
        if (successMsg) successMsg.style.display = 'block';
      } else {
        btn.innerHTML = originalText;
        btn.disabled = false;
        alert('Something went wrong. Please try again or email us directly.');
      }
    } catch {
      btn.innerHTML = originalText;
      btn.disabled = false;
      alert('Something went wrong. Please try again or email us directly.');
    }
  });
</script>

<style>
  .page-hero {
    background: var(--black);
    padding: 4rem 1.5rem 5rem;
    text-align: center;
  }

  .page-hero h1 {
    color: var(--white);
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
  }

  .page-hero__sub {
    color: rgba(255,255,255,0.85);
    font-size: 1.15rem;
    max-width: 520px;
    margin: 0 auto;
  }

  /* Contact layout */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
  }

  /* Form */
  .contact-form-wrap {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--r-lg);
    padding: 2.5rem;
    box-shadow: var(--shadow-md);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gray-700);
  }

  .req { color: #EF4444; }

  .form-group input,
  .form-group select,
  .form-group textarea {
    border: 1.5px solid var(--gray-200);
    border-radius: var(--r-sm);
    padding: 0.75rem 1rem;
    font-family: var(--font);
    font-size: 0.92rem;
    color: var(--gray-900);
    background: var(--white);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    width: 100%;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--green);
    box-shadow: 0 0 0 3px rgba(34,197,94,0.12);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-note {
    font-size: 0.85rem;
    color: #6B7280;
    text-align: center;
    margin: 0;
  }

  /* Success state */
  .form-success {
    text-align: center;
    padding: 3rem 2rem;
  }

  .success-icon {
    width: 64px;
    height: 64px;
    background: var(--green-light);
    color: var(--green-dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 auto 1.25rem;
  }

  .form-success h3 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--gray-900);
  }

  .form-success p {
    color: #4B5563;
    margin: 0;
  }

  /* Sidebar */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sidebar-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--r);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
  }

  .sidebar-card--dark {
    background: var(--black);
    border-color: var(--black);
  }

  .sidebar-card h3 {
    font-size: 1rem;
    margin-bottom: 1.25rem;
    color: var(--gray-900);
  }

  .next-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .next-steps li {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }

  .step-num-sm {
    width: 26px;
    height: 26px;
    background: var(--green);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .next-steps strong {
    display: block;
    font-size: 0.92rem;
    color: var(--gray-900);
    margin-bottom: 0.2rem;
  }

  .next-steps p {
    font-size: 0.88rem;
    color: #4B5563;
    margin: 0;
  }

  .sidebar-benefits {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .sidebar-benefits li {
    font-size: 0.92rem;
    color: rgba(255,255,255,0.88);
  }

  .email-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--green-dark);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.15s;
  }

  .email-link:hover {
    color: var(--green);
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .contact-sidebar {
      order: -1;
    }
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }
    .contact-form-wrap {
      padding: 1.5rem;
    }
  }
</style>
