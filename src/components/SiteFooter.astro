---
const year = new Date().getFullYear();

const services = [
  { label: 'Business Process Automation', href: '/services#bpa' },
  { label: 'Robotic Process Automation', href: '/services#rpa' },
  { label: 'API & Webhook Integration', href: '/services#api' },
  { label: 'CRM Automation', href: '/services#crm' },
  { label: 'Microsoft 365 Solutions', href: '/services#microsoft' },
  { label: 'Mobile & Web Development', href: '/services#dev' },
];

const company = [
  { label: 'About Us', href: '/about' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Blog', href: '/blog' },
  { label: 'Get a Quote', href: '/quote' },
  { label: 'Contact', href: '/contact' },
];

const tools = ['Make.com', 'n8n', 'Power Automate', 'UiPath', 'Microsoft 365', 'Flutter', 'Next.js'];
---

<footer class="footer">
  <div class="footer__inner">
    <!-- Brand -->
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="HashTurn Home">
        <span class="f-logo-mark" aria-hidden="true">
          <span class="flm-r"></span>
          <span class="flm-g"></span>
          <span class="flm-y"></span>
          <span class="flm-b"></span>
        </span>
        <span class="f-logo-text">HASHTURN</span>
      </a>
      <p class="footer__tagline">
        We automate the work.<br />You run the business.
      </p>
      <p class="footer__desc">
        Custom automation solutions for businesses ready to stop wasting time on manual tasks.
      </p>
      <!-- Social Links -->
      <div class="footer__socials">
        <a href="https://www.facebook.com/hashturnofficial/" target="_blank" rel="noopener noreferrer" aria-label="HashTurn on Facebook">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/hashturn/" target="_blank" rel="noopener noreferrer" aria-label="HashTurn on LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="https://medium.com/@hashturnofficial" target="_blank" rel="noopener noreferrer" aria-label="HashTurn on Medium">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
        </a>
        <a href="https://wa.me/923090483683" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
        </a>
      </div>

      <a href="/contact" class="btn btn--green" style="margin-top:1.5rem;">Book Free Strategy Call</a>
    </div>

    <!-- Services -->
    <div class="footer__col">
      <h2 class="footer__col-title">Services</h4>
      <ul>
        {services.map(s => (
          <li><a href={s.href}>{s.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Company -->
    <div class="footer__col">
      <h2 class="footer__col-title">Company</h4>
      <ul>
        {company.map(c => (
          <li><a href={c.href}>{c.label}</a></li>
        ))}
      </ul>

      <h2 class="footer__col-title" style="margin-top:2rem;">Contact</h2>
      <ul>
        <li><a href="mailto:hello@hashturn.com">hello@hashturn.com</a></li>
        <li><a href="/contact">Get a Free Quote</a></li>
      </ul>
    </div>
  </div>

  <!-- Tools strip -->
  <div class="footer__tools">
    <span class="footer__tools-label">Powered by:</span>
    {tools.map(t => <span class="footer__tool">{t}</span>)}
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <p>&copy; {year} HashTurn. All rights reserved.</p>
    <div class="footer__bottom-links">
      <a href="/privacy-policy">Privacy Policy</a>
      <a href="/terms">Terms of Service</a>
      <a href="/refund-policy">Refund Policy</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--black);
    color: rgba(255,255,255,0.65);
  }

  .footer__inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 4rem 1.5rem 3rem;
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr;
    gap: 3rem;
  }

  /* Logo */
  .footer__logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    margin-bottom: 1.5rem;
  }

  .f-logo-mark {
    width: 28px;
    height: 28px;
    position: relative;
    flex-shrink: 0;
  }

  .f-logo-mark span {
    position: absolute;
    border-radius: 2px;
  }

  .flm-r { width: 7px; height: 20px; background: #EF4444; left: 4px; top: 4px; z-index: 2; }
  .flm-y { width: 7px; height: 20px; background: #EAB308; left: 16px; top: 4px; z-index: 2; }
  .flm-g { width: 24px; height: 6px; background: #22C55E; left: 2px; top: 5px; z-index: 1; }
  .flm-b { width: 24px; height: 6px; background: #3B82F6; left: 2px; top: 15px; z-index: 1; }

  .f-logo-text {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--white);
  }

  .footer__tagline {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.4;
    margin-bottom: 0.75rem;
  }

  .footer__desc {
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Socials */
  .footer__socials {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .footer__socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.75);
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
  }

  .footer__socials a:hover {
    background: var(--green);
    color: var(--black);
  }

  /* Columns */
  .footer__col-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 1rem;
  }

  .footer__col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__col a {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer__col a:hover {
    color: var(--green);
  }

  /* Tools strip */
  .footer__tools {
    border-top: 1px solid rgba(255,255,255,0.08);
    max-width: var(--max);
    margin: 0 auto;
    padding: 1.5rem 1.5rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer__tools-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin-right: 0.25rem;
  }

  .footer__tool {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.65);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.3rem 0.75rem;
    border-radius: 50px;
  }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    max-width: var(--max);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.85rem;
  }

  .footer__bottom-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer__bottom-links a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer__bottom-links a:hover {
    color: rgba(255,255,255,0.7);
  }

  @media (max-width: 900px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer__bottom {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
