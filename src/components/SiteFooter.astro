---
const year = new Date().getFullYear();

const services = [
  { label: 'Business Process Automation', href: '/services#bpa' },
  { label: 'Robotic Process Automation', href: '/services#rpa' },
  { label: 'API & Webhook Integration', href: '/services#api' },
  { label: 'CRM Automation', href: '/services#crm' },
  { label: 'Microsoft 365 Solutions', href: '/services#microsoft' },
  { label: 'Mobile & Web Development', href: '/services#dev' },
];

const company = [
  { label: 'About Us', href: '/about' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Blog', href: '/blog' },
  { label: 'Get a Quote', href: '/quote' },
  { label: 'Contact', href: '/contact' },
];

const tools = ['Make.com', 'n8n', 'Power Automate', 'UiPath', 'Microsoft 365', 'Flutter', 'Next.js'];
---

<footer class="footer">
  <div class="footer__inner">
    <!-- Brand -->
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="HashTurn Home">
        <span class="f-logo-mark" aria-hidden="true">
          <span class="flm-r"></span>
          <span class="flm-g"></span>
          <span class="flm-y"></span>
          <span class="flm-b"></span>
        </span>
        <span class="f-logo-text">HASHTURN</span>
      </a>
      <p class="footer__tagline">
        We automate the work.<br />You run the business.
      </p>
      <p class="footer__desc">
        Custom automation solutions for businesses ready to stop wasting time on manual tasks.
      </p>
      <a href="/contact" class="btn btn--green" style="margin-top:1.5rem;">Book Free Strategy Call</a>
    </div>

    <!-- Services -->
    <div class="footer__col">
      <h2 class="footer__col-title">Services</h4>
      <ul>
        {services.map(s => (
          <li><a href={s.href}>{s.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Company -->
    <div class="footer__col">
      <h2 class="footer__col-title">Company</h4>
      <ul>
        {company.map(c => (
          <li><a href={c.href}>{c.label}</a></li>
        ))}
      </ul>

      <h2 class="footer__col-title" style="margin-top:2rem;">Contact</h2>
      <ul>
        <li><a href="mailto:hello@hashturn.com">hello@hashturn.com</a></li>
        <li><a href="/contact">Get a Free Quote</a></li>
      </ul>
    </div>
  </div>

  <!-- Tools strip -->
  <div class="footer__tools">
    <span class="footer__tools-label">Powered by:</span>
    {tools.map(t => <span class="footer__tool">{t}</span>)}
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <p>&copy; {year} HashTurn. All rights reserved.</p>
    <div class="footer__bottom-links">
      <a href="/privacy-policy">Privacy Policy</a>
      <a href="/terms">Terms of Service</a>
      <a href="/refund-policy">Refund Policy</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--black);
    color: rgba(255,255,255,0.65);
  }

  .footer__inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 4rem 1.5rem 3rem;
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr;
    gap: 3rem;
  }

  /* Logo */
  .footer__logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    margin-bottom: 1.5rem;
  }

  .f-logo-mark {
    width: 28px;
    height: 28px;
    position: relative;
    flex-shrink: 0;
  }

  .f-logo-mark span {
    position: absolute;
    border-radius: 2px;
  }

  .flm-r { width: 7px; height: 20px; background: #EF4444; left: 4px; top: 4px; z-index: 2; }
  .flm-y { width: 7px; height: 20px; background: #EAB308; left: 16px; top: 4px; z-index: 2; }
  .flm-g { width: 24px; height: 6px; background: #22C55E; left: 2px; top: 5px; z-index: 1; }
  .flm-b { width: 24px; height: 6px; background: #3B82F6; left: 2px; top: 15px; z-index: 1; }

  .f-logo-text {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--white);
  }

  .footer__tagline {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.4;
    margin-bottom: 0.75rem;
  }

  .footer__desc {
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Columns */
  .footer__col-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 1rem;
  }

  .footer__col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__col a {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer__col a:hover {
    color: var(--green);
  }

  /* Tools strip */
  .footer__tools {
    border-top: 1px solid rgba(255,255,255,0.08);
    max-width: var(--max);
    margin: 0 auto;
    padding: 1.5rem 1.5rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer__tools-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin-right: 0.25rem;
  }

  .footer__tool {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.65);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.3rem 0.75rem;
    border-radius: 50px;
  }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    max-width: var(--max);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.85rem;
  }

  .footer__bottom-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer__bottom-links a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer__bottom-links a:hover {
    color: rgba(255,255,255,0.7);
  }

  @media (max-width: 900px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer__bottom {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
