---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { sql } from '../../../lib/db';

const projects = await sql`SELECT slug, title, client, service, tools, featured FROM projects ORDER BY display_order ASC, created_at DESC`.catch(() => []);
---

<AdminLayout title="Projects" activeNav="projects">
  <div class="admin-card">
    <div class="admin-card__header">
      <span class="admin-card__title">Projects ({projects.length})</span>
      <a href="/admin/projects/new" class="btn-admin btn-admin--green">+ Add Project</a>
    </div>

    {projects.length === 0 ? (
      <div style="padding:2rem; text-align:center; color:#9CA3AF;">
        No projects yet. <a href="/admin/projects/new" style="color:#22C55E;">Add your first project →</a>
      </div>
    ) : (
      <div style="overflow-x:auto;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Project</th>
              <th>Client</th>
              <th>Service</th>
              <th>Tools</th>
              <th>Featured</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {(projects as any[]).map(p => {
              const toolsArr: string[] = JSON.parse(String(p.tools ?? '[]'));
              return (
                <tr>
                  <td style="font-weight:500;">{String(p.title)}</td>
                  <td style="color:#4B5563;">{String(p.client)}</td>
                  <td style="color:#6B7280; white-space:nowrap;">{String(p.service)}</td>
                  <td>
                    <div style="display:flex; gap:0.25rem; flex-wrap:wrap;">
                      {toolsArr.slice(0,3).map(t => <span class="tag-badge">{t}</span>)}
                      {toolsArr.length > 3 && <span style="font-size:0.75rem; color:#9CA3AF;">+{toolsArr.length - 3}</span>}
                    </div>
                  </td>
                  <td>
                    {p.featured
                      ? <span style="color:#22C55E; font-size:0.8rem; font-weight:600;">✓ Yes</span>
                      : <span style="color:#9CA3AF; font-size:0.8rem;">No</span>}
                  </td>
                  <td>
                    <div style="display:flex; gap:0.5rem;">
                      <a href={`/admin/projects/edit/${p.slug}`} class="btn-admin btn-admin--outline btn-admin--sm">Edit</a>
                      <a href={`/work/${p.slug}/`} target="_blank" class="btn-admin btn-admin--outline btn-admin--sm">View ↗</a>
                      <form method="POST" action="/admin/api/projects/delete" style="display:inline;" onsubmit="return confirm('Delete this project?')">
                        <input type="hidden" name="slug" value={String(p.slug)} />
                        <button type="submit" class="btn-admin btn-admin--danger btn-admin--sm">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AdminLayout>
