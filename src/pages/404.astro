---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="404: Page Not Found | HashTurn" 
  description="The page you are looking for doesn't exist or has been moved."
>
  <section class="error-container">
    <div class="content">
      <span class="error-code">404</span>
      <h1>Lost in Automation?</h1>
      <p>The page you're looking for has been moved, deleted, or never existed. Let's get you back on track.</p>
      
      <div class="actions">
        <a href="/" class="btn-primary">Back to Homepage</a>
        <a href="/contact" class="btn-secondary">Contact Support</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .error-container {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }

  .error-code {
    font-size: 1.25rem;
    font-weight: 600;
    color: #666;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: #111;
  }

  p {
    font-size: 1.1rem;
    color: #444;
    max-width: 500px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: #000;
    color: #fff;
    padding: 0.8rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .btn-secondary {
    border: 1px solid #ddd;
    color: #111;
    padding: 0.8rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    transition: background 0.2s;
  }

  .btn-primary:hover { opacity: 0.8; }
  .btn-secondary:hover { background: #f5f5f5; }
</style>