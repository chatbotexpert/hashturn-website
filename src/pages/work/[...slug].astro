---
export const prerender = false;
import { marked } from 'marked';
import BaseHead from '../../components/BaseHead.astro';
import Nav from '../../components/Nav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import CalendlyPopup from '../../components/CalendlyPopup.astro';
import { sql } from '../../lib/db';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/work');

const rows = await sql`SELECT * FROM projects WHERE slug=${slug}`.catch(() => []);
if (!rows.length) return Astro.redirect('/work');

const p = rows[0] as Record<string, unknown>;
const title = String(p.title ?? '');
const description = String(p.description ?? '');
const client = String(p.client ?? '');
const service = String(p.service ?? '');
const tools: string[] = JSON.parse(String(p.tools ?? '[]'));
const results = String(p.results ?? '');
const heroImage = String(p.hero_image ?? '');
const htmlContent = await marked(String(p.content ?? ''), { gfm: true });
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${title} — HashTurn`} description={description} image={heroImage || undefined} />
  </head>
  <body>
    <Nav />
    <main>
      <section class="project-hero">
        {heroImage && (
          <div class="project-hero__img">
            <img src={heroImage} alt={title} />
          </div>
        )}
        <div class="container">
          <a href="/work" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            All Projects
          </a>
          <div class="project-hero__meta">
            <span class="service-tag">{service}</span>
          </div>
          <h1>{title}</h1>
          <p class="project-hero__desc">{description}</p>
          <div class="project-hero__facts">
            <div class="fact">
              <span class="fact__label">Client</span>
              <span class="fact__value">{client}</span>
            </div>
            <div class="fact">
              <span class="fact__label">Result</span>
              <span class="fact__value result">{results}</span>
            </div>
            {tools.length > 0 && (
              <div class="fact">
                <span class="fact__label">Tools</span>
                <div class="fact__tools">
                  {tools.map(t => <span class="tool-badge">{t}</span>)}
                </div>
              </div>
            )}
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="project-layout">
            <article class="prose" set:html={htmlContent} />

            <aside class="project-sidebar">
              <div class="sidebar-card">
                <h3>Project Details</h3>
                <dl class="detail-list">
                  <div><dt>Client</dt><dd>{client}</dd></div>
                  <div><dt>Service</dt><dd>{service}</dd></div>
                  {tools.length > 0 && (
                    <div>
                      <dt>Tools</dt>
                      <dd><div class="tool-list">{tools.map(t => <span class="tool-badge">{t}</span>)}</div></dd>
                    </div>
                  )}
                  <div><dt>Result</dt><dd class="result-dd">{results}</dd></div>
                </dl>
              </div>
              <div class="sidebar-card sidebar-card--dark">
                <h3 style="color:var(--white);">Need Something Similar?</h3>
                <p>Book a free 30-minute strategy call and we'll show you how we'd build it for your business.</p>
                <a href="/contact" class="btn btn--green" style="width:100%; justify-content:center; margin-top:1rem;">
                  Book Free Call
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>
            </aside>
          </div>
        </div>
      </section>
    </main>
    <SiteFooter />
    <CalendlyPopup />
  </body>
</html>

<style>
  .project-hero { background:var(--black); padding-bottom:3rem; }
  .project-hero__img img { width:100%; max-height:400px; object-fit:cover; display:block; margin-bottom:2rem; }
  .project-hero .container { padding-top:2.5rem; }
  .back-link { display:inline-flex; align-items:center; gap:0.4rem; color:rgba(255,255,255,0.6); font-size:0.88rem; text-decoration:none; margin-bottom:1.25rem; transition:color 0.15s; }
  .back-link:hover { color:var(--white); }
  .project-hero__meta { margin-bottom:0.75rem; }
  .service-tag { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:var(--green); background:rgba(34,197,94,0.15); padding:0.25rem 0.7rem; border-radius:50px; }
  .project-hero h1 { color:var(--white); font-size:clamp(1.8rem,4vw,2.75rem); margin-bottom:1rem; max-width:780px; }
  .project-hero__desc { color:rgba(255,255,255,0.75); font-size:1.05rem; max-width:640px; line-height:1.7; margin-bottom:2rem; }
  .project-hero__facts { display:flex; flex-wrap:wrap; gap:2rem; padding-top:1.5rem; border-top:1px solid rgba(255,255,255,0.1); }
  .fact__label { display:block; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:rgba(255,255,255,0.45); margin-bottom:0.35rem; }
  .fact__value { font-size:0.92rem; color:rgba(255,255,255,0.85); }
  .fact__value.result { color:var(--green); font-weight:600; }
  .fact__tools { display:flex; flex-wrap:wrap; gap:0.35rem; }
  .tool-badge { font-size:0.72rem; font-weight:600; color:#374151; background:#F3F4F6; padding:0.2rem 0.55rem; border-radius:4px; }
  .project-hero .tool-badge { color:rgba(255,255,255,0.75); background:rgba(255,255,255,0.1); }
  .project-layout { display:grid; grid-template-columns:1fr 300px; gap:3rem; align-items:start; }
  .prose { font-size:1.02rem; line-height:1.8; color:var(--gray-700); }
  .prose :global(h2) { font-size:1.4rem; color:var(--gray-900); margin-top:2.5rem; margin-bottom:0.75rem; }
  .prose :global(h3) { font-size:1.1rem; color:var(--gray-900); margin-top:1.75rem; margin-bottom:0.5rem; }
  .prose :global(p) { margin-bottom:1.25rem; }
  .prose :global(ul), .prose :global(ol) { padding-left:1.5rem; margin-bottom:1.25rem; }
  .prose :global(li) { margin-bottom:0.4rem; }
  .prose :global(a) { color:var(--green-dark); text-decoration:underline; }
  .prose :global(table) { width:100%; border-collapse:collapse; margin:1.5rem 0; font-size:0.92rem; }
  .prose :global(th) { background:#F9FAFB; padding:0.65rem 1rem; text-align:left; font-weight:600; border:1px solid var(--gray-200); }
  .prose :global(td) { padding:0.65rem 1rem; border:1px solid var(--gray-200); }
  .prose :global(tr:nth-child(even) td) { background:#F9FAFB; }
  .prose :global(img) { max-width:100%; border-radius:var(--r); margin:1.5rem auto; display:block; }
  .prose :global(blockquote) { border-left:4px solid var(--green); margin:1.5rem 0; padding:0.75rem 1.25rem; background:var(--green-light); border-radius:0 var(--r-sm) var(--r-sm) 0; }
  .prose :global(code) { background:#F3F4F6; padding:0.15rem 0.4rem; border-radius:4px; font-size:0.88em; }
  .prose :global(pre) { background:#1E293B; color:#E2E8F0; padding:1.25rem; border-radius:var(--r-sm); overflow-x:auto; margin:1.5rem 0; }
  .prose :global(pre code) { background:none; padding:0; }
  .prose :global(strong) { color:var(--gray-900); }
  .prose :global(hr) { border:none; border-top:1px solid var(--gray-200); margin:2rem 0; }
  .project-sidebar { display:flex; flex-direction:column; gap:1.25rem; position:sticky; top:6rem; }
  .sidebar-card { background:var(--white); border:1px solid var(--gray-200); border-radius:var(--r); padding:1.5rem; box-shadow:var(--shadow-sm); }
  .sidebar-card--dark { background:var(--black); border-color:var(--black); }
  .sidebar-card--dark p { color:rgba(255,255,255,0.7); font-size:0.88rem; margin:0; }
  .sidebar-card h3 { font-size:0.95rem; color:var(--gray-900); margin-bottom:1.25rem; }
  .detail-list { display:flex; flex-direction:column; gap:1rem; }
  .detail-list dt { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:var(--gray-400); margin-bottom:0.2rem; }
  .detail-list dd { font-size:0.9rem; color:var(--gray-700); margin:0; }
  .result-dd { color:var(--green-dark) !important; font-weight:600 !important; }
  .tool-list { display:flex; flex-wrap:wrap; gap:0.35rem; }
  @media (max-width:900px) { .project-layout { grid-template-columns:1fr; } .project-sidebar { position:static; order:-1; } }
</style>
