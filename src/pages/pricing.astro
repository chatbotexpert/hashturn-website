---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="HashTurn Pricing — Automation & Development Packages"
  description="Flexible automation packages for every business size. From simple workflow automation to enterprise RPA and custom development."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container text-center">
      <p class="section-label">Pricing</p>
      <h1 style="color:var(--white);">Simple, Transparent Pricing</h1>
      <p style="color:rgba(255,255,255,0.65); max-width:520px; margin:0.75rem auto 0; font-size:1.05rem;">
        No hidden fees. No surprises. Pick a package or get a custom quote for your specific project.
      </p>

      <!-- Billing Toggle -->
      <div class="billing-toggle">
        <input type="checkbox" id="billing-toggle" class="billing-input" />
        <label for="billing-toggle" class="billing-label">
          <span class="billing-opt billing-opt--monthly">Monthly</span>
          <span class="billing-switch"></span>
          <span class="billing-opt billing-opt--annual">Annual <span class="save-badge">Save 20%</span></span>
        </label>
      </div>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="section">
    <div class="container">
      <div class="pricing-grid">

        <!-- Starter -->
        <div class="pricing-card">
          <div class="pricing-card__header">
            <div class="plan-icon">&#9889;</div>
            <h2>Starter</h2>
            <p class="plan-desc">Perfect for small businesses looking to automate one key workflow.</p>
          </div>
          <div class="pricing-card__price">
            <span class="price monthly-price">$49</span>
            <span class="price annual-price">$39</span>
            <span class="price-period">/project</span>
          </div>
          <ul class="plan-features">
            <li><span class="feat-check">&#10003;</span> 1 automation workflow</li>
            <li><span class="feat-check">&#10003;</span> Up to 3 app integrations</li>
            <li><span class="feat-check">&#10003;</span> Make.com or n8n</li>
            <li><span class="feat-check">&#10003;</span> 7-day delivery</li>
            <li><span class="feat-check">&#10003;</span> 14 days of support</li>
            <li><span class="feat-muted">&#8212;</span> Custom development</li>
            <li><span class="feat-muted">&#8212;</span> Ongoing maintenance</li>
          </ul>
          <a href="/contact" class="btn btn--outline-dark" style="width:100%; justify-content:center;">Get Started</a>
        </div>

        <!-- Growth (Featured) -->
        <div class="pricing-card pricing-card--featured">
          <div class="popular-badge">Most Popular</div>
          <div class="pricing-card__header">
            <div class="plan-icon">&#128640;</div>
            <h2>Growth</h2>
            <p class="plan-desc">For growing businesses that need multiple automations and integrations.</p>
          </div>
          <div class="pricing-card__price">
            <span class="price monthly-price">$499</span>
            <span class="price annual-price">$399</span>
            <span class="price-period">/project</span>
          </div>
          <ul class="plan-features">
            <li><span class="feat-check">&#10003;</span> Up to 5 automation workflows</li>
            <li><span class="feat-check">&#10003;</span> Unlimited app integrations</li>
            <li><span class="feat-check">&#10003;</span> Make.com, n8n, Power Automate, or UiPath</li>
            <li><span class="feat-check">&#10003;</span> 14-day delivery</li>
            <li><span class="feat-check">&#10003;</span> 30 days of support</li>
            <li><span class="feat-check">&#10003;</span> CRM automation included</li>
            <li><span class="feat-muted">&#8212;</span> Custom app development</li>
          </ul>
          <a href="/contact" class="btn btn--green" style="width:100%; justify-content:center;" data-calendly="true">Get Started</a>
        </div>

        <!-- Enterprise -->
        <div class="pricing-card">
          <div class="pricing-card__header">
            <div class="plan-icon">&#127970;</div>
            <h2>Enterprise</h2>
            <p class="plan-desc">Full-scale automation, custom development, and ongoing partnership.</p>
          </div>
          <div class="pricing-card__price">
            <span class="price">Custom</span>
            <span class="price-period"></span>
          </div>
          <ul class="plan-features">
            <li><span class="feat-check">&#10003;</span> Unlimited automation workflows</li>
            <li><span class="feat-check">&#10003;</span> Full Microsoft 365 / RPA suite</li>
            <li><span class="feat-check">&#10003;</span> Custom app development (web/mobile)</li>
            <li><span class="feat-check">&#10003;</span> Dedicated project manager</li>
            <li><span class="feat-check">&#10003;</span> Ongoing maintenance &amp; support</li>
            <li><span class="feat-check">&#10003;</span> SLA guarantee</li>
            <li><span class="feat-check">&#10003;</span> Team training included</li>
          </ul>
          <a href="/contact" class="btn btn--outline-dark" style="width:100%; justify-content:center;">Contact Us</a>
        </div>

      </div>

      <!-- Note -->
      <p class="pricing-note">
        &#128276; All prices are starting estimates. Final pricing depends on project complexity.
        <a href="/contact">Get a free custom quote &rarr;</a>
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--gray">
    <div class="container">
      <div class="text-center" style="margin-bottom:3rem;">
        <p class="section-label">Questions</p>
        <h2 class="section-title">Frequently Asked Questions</h2>
      </div>
      <div class="faq-grid">
        <div class="faq-item">
          <h3>How long does a project take?</h3>
          <p>Most automation projects are delivered in 3–14 days depending on complexity. We give you a clear timeline upfront before starting.</p>
        </div>
        <div class="faq-item">
          <h3>Do I need technical knowledge?</h3>
          <p>Not at all. We handle everything — you just tell us what you want automated. We translate your business requirements into working systems.</p>
        </div>
        <div class="faq-item">
          <h3>What if I need changes after delivery?</h3>
          <p>We include a support period with every project. Minor adjustments are covered. Major additions are quoted separately with priority turnaround.</p>
        </div>
        <div class="faq-item">
          <h3>Can I pay per hour instead?</h3>
          <p>Yes. For complex or ongoing projects, we also offer hourly retainer arrangements. Contact us to discuss which model works best for you.</p>
        </div>
        <div class="faq-item">
          <h3>What's your refund policy?</h3>
          <p>We stand behind our work. If we can't deliver what we promised, you get a full refund. See our <a href="/refund-policy">Refund Policy</a> for details.</p>
        </div>
        <div class="faq-item">
          <h3>Do you work with international clients?</h3>
          <p>Absolutely. We serve clients across the USA, UK, Europe, Middle East, and Asia. All projects are managed remotely with clear communication.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container text-center">
      <p class="section-label" style="color:var(--green);">Get Started</p>
      <h2 style="color:var(--white); font-size:clamp(1.7rem,3.5vw,2.75rem); margin-bottom:1rem;">
        Not sure which package is right?
      </h2>
      <p style="color:rgba(255,255,255,0.6); max-width:440px; margin:0 auto 2.5rem; font-size:1.05rem;">
        Book a free 30-minute call and we'll recommend exactly what you need.
      </p>
      <a href="/contact" class="btn btn--green btn--lg" data-calendly="true">
        Book Free Strategy Call &rarr;
      </a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: var(--black);
    padding: 4rem 1.5rem 5rem;
  }

  /* Billing toggle */
  .billing-toggle {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }

  .billing-input { display: none; }

  .billing-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    user-select: none;
  }

  .billing-opt {
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }

  .billing-switch {
    width: 44px;
    height: 24px;
    background: rgba(255,255,255,0.15);
    border-radius: 12px;
    position: relative;
    transition: background 0.2s;
    flex-shrink: 0;
  }

  .billing-switch::after {
    content: '';
    position: absolute;
    width: 18px;
    height: 18px;
    background: var(--white);
    border-radius: 50%;
    top: 3px;
    left: 3px;
    transition: transform 0.2s;
  }

  .billing-input:checked ~ .billing-label .billing-switch {
    background: var(--green);
  }

  .billing-input:checked ~ .billing-label .billing-switch::after {
    transform: translateX(20px);
  }

  .billing-input:checked ~ .billing-label .billing-opt--annual {
    color: var(--white);
  }

  .billing-input:not(:checked) ~ .billing-label .billing-opt--monthly {
    color: var(--white);
  }

  .save-badge {
    display: inline-block;
    background: var(--green);
    color: var(--white);
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 50px;
    margin-left: 0.35rem;
    vertical-align: middle;
  }

  /* Monthly/Annual price switching */
  .annual-price { display: none; }

  /* Controlled via sibling selector trick — need JS for cross-section toggle */

  /* Pricing grid */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
    margin-bottom: 2rem;
  }

  .pricing-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--r-lg);
    padding: 2rem;
    position: relative;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .pricing-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .pricing-card--featured {
    border: 2px solid var(--green);
    box-shadow: 0 8px 30px rgba(34,197,94,0.15);
    transform: scale(1.02);
  }

  .pricing-card--featured:hover {
    transform: scale(1.02) translateY(-4px);
  }

  .popular-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--green);
    color: var(--white);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 1rem;
    border-radius: 50px;
    white-space: nowrap;
  }

  .plan-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .pricing-card__header h2 {
    font-size: 1.3rem;
    margin-bottom: 0.4rem;
  }

  .plan-desc {
    font-size: 0.88rem;
    color: var(--gray-500);
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .pricing-card__price {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--gray-200);
  }

  .price {
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--gray-900);
  }

  .price-period {
    font-size: 0.88rem;
    color: var(--gray-400);
    margin-left: 0.25rem;
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .plan-features li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: var(--gray-700);
  }

  .feat-check {
    color: var(--green-dark);
    font-weight: 700;
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .feat-muted {
    color: var(--gray-300);
    flex-shrink: 0;
  }

  .plan-features li:has(.feat-muted) {
    color: var(--gray-400);
  }

  .pricing-note {
    text-align: center;
    font-size: 0.88rem;
    color: var(--gray-400);
    margin-top: 1rem;
  }

  .pricing-note a {
    color: var(--green-dark);
    font-weight: 600;
    text-decoration: underline;
  }

  /* FAQ */
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .faq-item {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--r);
    padding: 1.75rem;
  }

  .faq-item h3 {
    font-size: 0.95rem;
    margin-bottom: 0.6rem;
    color: var(--gray-900);
  }

  .faq-item p {
    font-size: 0.88rem;
    color: var(--gray-500);
    margin: 0;
    line-height: 1.65;
  }

  .faq-item a {
    color: var(--green-dark);
    text-decoration: underline;
  }

  /* CTA */
  .cta-section {
    background: var(--black);
    padding: 5rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(34,197,94,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-section .container { position: relative; z-index: 1; }

  @media (max-width: 900px) {
    .pricing-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto 2rem; }
    .pricing-card--featured { transform: none; }
    .faq-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Billing toggle — show/hide monthly vs annual prices
  const toggle = document.getElementById('billing-toggle') as HTMLInputElement;
  const monthlyPrices = document.querySelectorAll('.monthly-price');
  const annualPrices = document.querySelectorAll('.annual-price');

  toggle?.addEventListener('change', () => {
    const isAnnual = toggle.checked;
    monthlyPrices.forEach(el => (el as HTMLElement).style.display = isAnnual ? 'none' : 'inline');
    annualPrices.forEach(el => (el as HTMLElement).style.display = isAnnual ? 'inline' : 'none');
  });
</script>
