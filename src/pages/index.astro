---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { sql } from '../lib/db';

const dbReviews = await sql`SELECT id, name, location, initials, rating, review_text AS text, source FROM reviews WHERE featured=true ORDER BY created_at DESC`.catch(() => []);
const featuredReviews = dbReviews as any[];
---

<Layout
  title="HashTurn — Business Automation Experts | Save Time, Cut Costs"
  description="HashTurn builds custom automation systems that eliminate repetitive tasks, connect your apps, and save your team hundreds of hours every month. 200+ projects delivered."
>

  <!-- =========================================
       HERO
  ========================================= -->
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__badge">
        <span class="badge-dot"></span>
        Trusted by 200+ businesses worldwide
      </div>

      <h1 class="hero__title">
        We Automate the Work.<br />
        <span class="hero__title-accent">You Run the Business.</span>
      </h1>

      <p class="hero__sub">
        HashTurn designs and builds custom automation systems — connecting your apps,
        eliminating repetitive tasks, and giving your team back hundreds of hours every month.
      </p>

      <div class="hero__ctas">
        <a href="/contact" class="btn btn--green btn--lg" data-calendly="true">
          Book Free Strategy Call
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/services" class="btn btn--outline-white btn--lg">See Our Services</a>
      </div>

      <div class="hero__trust">
        <div class="trust-item">
          <strong>200+</strong>
          <span>Projects Delivered</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <strong>&#11088; 5.0</strong>
          <span>Fiverr Rating</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <strong>Fast</strong>
          <span>Turnaround</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <strong>100%</strong>
          <span>Client Satisfaction</span>
        </div>
      </div>
    </div>

    <!-- Decorative shapes (right side) -->
    <div class="hero__shapes" aria-hidden="true">
      <!-- Large hollow circle -->
      <svg class="shape shape--circle" viewBox="0 0 320 320" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="160" cy="160" r="150" stroke="#22C55E" stroke-width="1.5"/>
        <circle cx="160" cy="160" r="110" stroke="#22C55E" stroke-width="0.75" stroke-dasharray="6 8"/>
      </svg>
      <!-- Rotated square -->
      <div class="shape shape--square"></div>
      <!-- Small accent square -->
      <div class="shape shape--square-sm"></div>
      <!-- Dot grid -->
      <div class="shape shape--dots"></div>
      <!-- Floating lines -->
      <svg class="shape shape--lines" viewBox="0 0 200 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="0" y1="10" x2="200" y2="10" stroke="#22C55E" stroke-width="1" stroke-dasharray="4 6"/>
        <line x1="0" y1="30" x2="160" y2="30" stroke="#3B82F6" stroke-width="1" stroke-dasharray="4 6"/>
        <line x1="0" y1="50" x2="120" y2="50" stroke="#22C55E" stroke-width="1" stroke-dasharray="4 6"/>
        <line x1="0" y1="70" x2="80" y2="70" stroke="white" stroke-width="0.5" stroke-dasharray="3 8"/>
      </svg>
    </div>

    <div class="hero__bg" aria-hidden="true">
      <div class="hero__blob hero__blob--1"></div>
      <div class="hero__blob hero__blob--2"></div>
    </div>
  </section>

  <!-- =========================================
       PROBLEM / VALUE PROP
  ========================================= -->
  <section class="section section--gray">
    <div class="container text-center">
      <p class="section-label">The Problem We Solve</p>
      <h2 class="section-title">Your Team Spends Too Much Time on Tasks<br />That Shouldn't Exist</h2>
      <p class="section-sub" style="margin: 0 auto 3rem; text-align: center;">
        Data entry, copy-pasting between apps, sending the same emails, generating the same reports —
        these tasks eat hours every day. HashTurn eliminates them so your team can focus on what actually matters.
      </p>

      <div class="pain-grid">
        <div class="pain-item pain-item--before">
          <div class="pain-label">Before HashTurn</div>
          <ul>
            <li>Manual data entry takes hours daily</li>
            <li>Errors from copy-pasting between systems</li>
            <li>Missed follow-ups and lost leads</li>
            <li>Your team doing robot work</li>
            <li>Money wasted on preventable mistakes</li>
          </ul>
        </div>
        <div class="pain-arrow" aria-hidden="true">&rarr;</div>
        <div class="pain-item pain-item--after">
          <div class="pain-label">After HashTurn</div>
          <ul>
            <li>Data flows automatically between all your apps</li>
            <li>Zero errors &mdash; bots are accurate every time</li>
            <li>Every lead is followed up instantly</li>
            <li>Your team focused on high-value work</li>
            <li>Hours saved turned into revenue</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================
       SERVICES
  ========================================= -->
  <section class="section" id="services">
    <div class="container">
      <div class="services__header">
        <div>
          <p class="section-label">What We Do</p>
          <h2 class="section-title">Automation Solutions for<br />Every Business Need</h2>
        </div>
        <a href="/services" class="btn btn--outline-dark">View All Services</a>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon" style="background:#DCFCE7; color:#16A34A;">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3>Business Process Automation</h3>
          <p>Map, optimize, and automate your entire business workflows — from lead capture to invoice generation — without disrupting how your team works.</p>
          <a href="/services#bpa" class="service-link">Learn about Business Process Automation &rarr;</a>
        </div>

        <div class="service-card">
          <div class="service-icon" style="background:#FEF3C7; color:#D97706;">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3>Robotic Process Automation (RPA)</h3>
          <p>Software robots that handle repetitive computer tasks 24/7 — logging in, extracting data, filling forms, generating reports — with perfect accuracy.</p>
          <a href="/services#rpa" class="service-link">Learn about Robotic Process Automation &rarr;</a>
        </div>

        <div class="service-card">
          <div class="service-icon" style="background:#DBEAFE; color:#2563EB;">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </div>
          <h3>API &amp; Webhook Integration</h3>
          <p>Connect any two apps — even if they weren't built to work together. We sync your CRM, ERP, ecommerce store, and every other tool in real-time.</p>
          <a href="/services#api" class="service-link">Learn about API &amp; Webhook Integration &rarr;</a>
        </div>

        <div class="service-card">
          <div class="service-icon" style="background:#FCE7F3; color:#DB2777;">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>CRM Automation</h3>
          <p>Automate your entire sales pipeline — lead scoring, follow-up sequences, deal tracking, and reporting — so your sales team only does selling.</p>
          <a href="/services#crm" class="service-link">Learn about CRM Automation &rarr;</a>
        </div>

        <div class="service-card">
          <div class="service-icon" style="background:#EDE9FE; color:#7C3AED;">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Microsoft 365 Solutions</h3>
          <p>SharePoint, Power Apps, Power Automate, Excel VBA, Office Scripts — we build custom tools and automations deep inside your Microsoft environment.</p>
          <a href="/services#microsoft" class="service-link">Learn about Microsoft 365 Solutions &rarr;</a>
        </div>

        <div class="service-card">
          <div class="service-icon" style="background:#D1FAE5; color:#059669;">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
          </div>
          <h3>Mobile &amp; Web Development</h3>
          <p>Custom apps built with Flutter, React Native, Next.js, and more. Ecommerce stores, customer portals, internal dashboards — we build it all.</p>
          <a href="/services#dev" class="service-link">Learn about Mobile &amp; Web Development &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================
       STATS
  ========================================= -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <div class="stat-number">200+</div>
          <div class="stat-label">Projects Delivered</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">50+</div>
          <div class="stat-label">Happy Clients</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">5,000+</div>
          <div class="stat-label">Hours Saved for Clients</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">5&#9733;</div>
          <div class="stat-label">Average Fiverr Rating</div>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================
       TOOLS WE USE
  ========================================= -->
  <section class="section section--gray">
    <div class="container text-center">
      <p class="section-label">Our Toolkit</p>
      <h2 class="section-title" style="margin-bottom:0.5rem;">Industry-Leading Tools</h2>
      <p class="section-sub" style="margin: 0 auto 3rem;">
        We are certified experts in the platforms businesses trust most.
      </p>

      <div class="tools-grid">
        <div class="tool-badge"><span>&#9881;</span> Make.com</div>
        <div class="tool-badge"><span>&#128260;</span> n8n</div>
        <div class="tool-badge"><span>&#9889;</span> Power Automate</div>
        <div class="tool-badge"><span>&#129302;</span> UiPath</div>
        <div class="tool-badge"><span>&#127970;</span> Microsoft 365</div>
        <div class="tool-badge"><span>&#128241;</span> Flutter</div>
        <div class="tool-badge"><span>&#9883;</span> React Native</div>
        <div class="tool-badge"><span>&#127760;</span> Next.js</div>
        <div class="tool-badge"><span>&#128722;</span> Shopify</div>
      </div>
    </div>
  </section>

  <!-- =========================================
       HOW IT WORKS
  ========================================= -->
  <section class="section" id="process">
    <div class="container text-center">
      <p class="section-label">Our Process</p>
      <h2 class="section-title">From Idea to Automation in 4 Simple Steps</h2>
      <p class="section-sub" style="margin: 0 auto 3.5rem;">
        We make the whole process simple, clear, and collaborative — no technical knowledge required on your end.
      </p>

      <div class="process-grid">
        <div class="process-step">
          <div class="step-num">1</div>
          <h3>Free Discovery Call</h3>
          <p>We learn about your business, your current workflows, and where you are losing the most time. No cost, no commitment.</p>
        </div>
        <div class="process-connector" aria-hidden="true">&rarr;</div>
        <div class="process-step">
          <div class="step-num">2</div>
          <h3>Strategy &amp; Plan</h3>
          <p>We design a custom automation roadmap — exactly what will be built, how it works, and the time and cost you will save.</p>
        </div>
        <div class="process-connector" aria-hidden="true">&rarr;</div>
        <div class="process-step">
          <div class="step-num">3</div>
          <h3>Build &amp; Test</h3>
          <p>Our team builds and thoroughly tests your automation. You are updated every step of the way until everything is perfect.</p>
        </div>
        <div class="process-connector" aria-hidden="true">&rarr;</div>
        <div class="process-step">
          <div class="step-num">4</div>
          <h3>Launch &amp; Support</h3>
          <p>We go live and provide ongoing support. Your automation runs reliably — and we are here if anything needs adjusting.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================
       TESTIMONIALS
  ========================================= -->
  <section class="section section--gray" id="reviews">
    <div class="container">
      <div class="text-center" style="margin-bottom:3rem;">
        <p class="section-label">Client Reviews</p>
        <h2 class="section-title">What Our Clients Say</h2>
        <p class="section-sub" style="margin: 0 auto;">
          200+ projects delivered on Fiverr &mdash; here is what businesses say about working with us.
        </p>
      </div>

      <div class="testimonials-grid">
        {featuredReviews.map(review => (
          <div class="testimonial-card">
            <div class="stars">{'★'.repeat(Number(review.rating))}{'☆'.repeat(5 - Number(review.rating))}</div>
            <p class="testimonial-text">"{String(review.text)}"</p>
            <div class="testimonial-author">
              <div class="author-avatar">{String(review.initials)}</div>
              <div>
                <strong>{String(review.name)}</strong>
                <span>{String(review.location)}</span>
              </div>
            </div>
            <div class="fiverr-badge">&#11088; {String(review.source).toLowerCase() === 'fiverr' ? 'Fiverr Verified Review' : `${String(review.source)} Review`}</div>
          </div>
        ))}
      </div>

      <div class="text-center" style="margin-top:2.5rem;">
        <a href="https://www.fiverr.com/zeeshaanbillal?public_mode=true" target="_blank" rel="noopener" class="btn btn--outline-dark">
          See All Reviews on Fiverr
        </a>
      </div>
    </div>
  </section>

  <!-- =========================================
       WHY HASHTURN
  ========================================= -->
  <section class="section">
    <div class="container">
      <div class="why-grid">
        <div class="why__content">
          <p class="section-label">Why HashTurn</p>
          <h2 class="section-title">Automation Built for Your Business, Not a Generic Template</h2>
          <p style="color:#4B5563; margin-bottom:2rem; font-size:1rem;">
            Unlike off-the-shelf software, every automation we build is custom-designed for your
            exact workflows. We take the time to understand your business before writing a single line of code.
          </p>

          <ul class="why-list">
            <li>
              <div class="why-check">&#10003;</div>
              <div>
                <strong>200+ successfully delivered projects</strong>
                <p>Proven track record across industries &mdash; retail, finance, healthcare, logistics, and more.</p>
              </div>
            </li>
            <li>
              <div class="why-check">&#10003;</div>
              <div>
                <strong>End-to-end service</strong>
                <p>From strategy to build to support &mdash; you get one dedicated team from start to finish.</p>
              </div>
            </li>
            <li>
              <div class="why-check">&#10003;</div>
              <div>
                <strong>Fast delivery, clear communication</strong>
                <p>Most projects delivered in days, not months. You are always in the loop with progress updates.</p>
              </div>
            </li>
            <li>
              <div class="why-check">&#10003;</div>
              <div>
                <strong>Microsoft-certified expertise</strong>
                <p>Deep experience with the full Microsoft ecosystem &mdash; Power Platform, SharePoint, Excel VBA, and beyond.</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="why__visual">
          <div class="why-card-stack">
            <div class="why-stat-card">
              <div class="why-stat-num">3 hrs</div>
              <div class="why-stat-lbl">Average daily time saved per client</div>
            </div>
            <div class="why-stat-card why-stat-card--green">
              <div class="why-stat-num">98%</div>
              <div class="why-stat-lbl">Client satisfaction rate</div>
            </div>
            <div class="why-stat-card">
              <div class="why-stat-num">&lt;48h</div>
              <div class="why-stat-lbl">Average project kickoff time</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================
       CTA SECTION
  ========================================= -->
  <section class="cta-section">
    <div class="container text-center">
      <p class="section-label" style="color:var(--green);">Ready to Automate?</p>
      <h2 style="color:var(--white); font-size:clamp(1.8rem,4vw,3rem); margin-bottom:1.25rem;">
        Stop Losing Hours to Tasks<br />a Robot Can Do Better.
      </h2>
      <p style="color:rgba(255,255,255,0.85); font-size:1.1rem; max-width:540px; margin:0 auto 2.5rem;">
        Book a free 30-minute strategy call. We will map out exactly how automation can save
        your business time and money &mdash; no obligation, no cost.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/contact" class="btn btn--green btn--lg" data-calendly="true">
          Book Free Strategy Call
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/services" class="btn btn--outline-white btn--lg">View All Services</a>
      </div>
      <p style="color:rgba(255,255,255,0.6); font-size:0.88rem; margin-top:1.5rem;">
        Free call &nbsp;&middot;&nbsp; No credit card required &nbsp;&middot;&nbsp; Response within 24 hours
      </p>
    </div>
  </section>

</Layout>

<style>
  /* ---- HERO ---- */
  .hero {
    background: var(--black);
    padding: 5rem 1.5rem 6rem;
    position: relative;
    overflow: hidden;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(34,197,94,0.12);
    border: 1px solid rgba(34,197,94,0.25);
    color: var(--green);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.45rem 1rem;
    border-radius: 50px;
    margin-bottom: 1.75rem;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse-dot 2s infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  .hero__title {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    max-width: 820px;
  }

  .hero__title-accent { color: var(--green); }

  .hero__sub {
    font-size: 1.2rem;
    color: rgba(255,255,255,0.85);
    max-width: 580px;
    line-height: 1.75;
    margin-bottom: 2.5rem;
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .hero__trust {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .trust-item { display: flex; flex-direction: column; }

  .trust-item strong {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
  }

  .trust-item span {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.65);
    margin-top: 0.2rem;
  }

  .trust-divider {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,0.1);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.1;
  }

  .hero__blob--1 {
    width: 500px; height: 500px;
    background: var(--green);
    right: -100px; top: -100px;
  }

  .hero__blob--2 {
    width: 350px; height: 350px;
    background: #3B82F6;
    right: 250px; bottom: -50px;
  }

  /* ---- HERO SHAPES ---- */
  .hero__shapes {
    position: absolute;
    right: 0;
    top: 0;
    width: 50%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .shape {
    position: absolute;
  }

  .shape--circle {
    width: 380px;
    height: 380px;
    right: -40px;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.18;
  }

  .shape--square {
    width: 70px;
    height: 70px;
    background: var(--green);
    border-radius: 10px;
    right: 15%;
    top: 18%;
    transform: rotate(30deg);
    opacity: 0.14;
  }

  .shape--square-sm {
    width: 36px;
    height: 36px;
    background: #3B82F6;
    border-radius: 6px;
    right: 32%;
    bottom: 22%;
    transform: rotate(20deg);
    opacity: 0.18;
  }

  .shape--dots {
    right: 8%;
    bottom: 15%;
    width: 130px;
    height: 130px;
    background-image: radial-gradient(circle, rgba(34,197,94,0.5) 1.5px, transparent 1.5px);
    background-size: 18px 18px;
    opacity: 0.25;
  }

  .shape--lines {
    width: 200px;
    left: 10%;
    top: 30%;
    opacity: 0.22;
  }

  /* ---- PAIN SECTION ---- */
  .pain-grid {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .pain-item {
    flex: 1;
    background: var(--white);
    border-radius: var(--r);
    padding: 2rem;
    text-align: left;
    box-shadow: var(--shadow-md);
  }

  .pain-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .pain-item--before .pain-label { color: #B91C1C; }
  .pain-item--after .pain-label { color: #15803D; }

  .pain-item ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    font-size: 0.9rem;
    padding: 0;
    margin: 0;
  }

  .pain-item--before li {
    color: var(--gray-500);
    padding-left: 1.5rem;
    position: relative;
  }
  .pain-item--before li::before {
    content: '✗';
