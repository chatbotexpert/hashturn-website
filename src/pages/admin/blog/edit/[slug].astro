---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/admin/blog');

const blogDir = join(process.cwd(), 'src', 'content', 'blog');

let title = '';
let description = '';
let pubDate = new Date().toISOString().split('T')[0];
let author = 'HashTurn Team';
let tags = '';
let content = '';
let heroImage = '';
let notFound = false;

try {
  let raw = '';
  try {
    raw = await readFile(join(blogDir, `${slug}.md`), 'utf-8');
  } catch {
    raw = await readFile(join(blogDir, `${slug}.mdx`), 'utf-8');
  }

  // Parse frontmatter
  const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
  if (fmMatch) {
    const fm = fmMatch[1];
    content = fmMatch[2].trim();

    const titleMatch = fm.match(/^title:\s*"?([^"\n]+)"?/m);
    const descMatch = fm.match(/^description:\s*"?([^"\n]+)"?/m);
    const dateMatch = fm.match(/^pubDate:\s*"?([^"\n]+)"?/m);
    const authorMatch = fm.match(/^author:\s*"?([^"\n]+)"?/m);
    const tagsMatch = fm.match(/^tags:\s*\[([^\]]*)\]/m);
    const heroMatch = fm.match(/^heroImage:\s*"?([^"\n]+)"?/m);

    title = titleMatch?.[1]?.trim() ?? '';
    description = descMatch?.[1]?.trim() ?? '';
    pubDate = dateMatch?.[1]?.trim() ?? pubDate;
    author = authorMatch?.[1]?.trim() ?? author;
    tags = tagsMatch?.[1]
      ? tagsMatch[1].split(',').map(t => t.trim().replace(/^"|"$/g, '')).filter(Boolean).join(', ')
      : '';
    heroImage = heroMatch?.[1]?.trim() ?? '';
  }
} catch {
  notFound = true;
}

if (notFound) return Astro.redirect('/admin/blog');
---

<AdminLayout title={`Edit: ${title}`} activeNav="blog">
  <div class="admin-card">
    <div class="admin-card__header">
      <span class="admin-card__title">Edit Post</span>
      <a href="/admin/blog" class="btn-admin btn-admin--outline">← Back</a>
    </div>

    <form method="POST" action="/admin/api/blog/update" enctype="multipart/form-data" style="padding:1.5rem; display:flex; flex-direction:column; gap:1.25rem;">
      <input type="hidden" name="slug" value={slug} />
      <input type="hidden" name="currentHeroImage" value={heroImage} />

      <div class="form-row">
        <div class="form-group">
          <label for="title">Title *</label>
          <input type="text" id="title" name="title" required value={title} />
        </div>
        <div class="form-group">
          <label for="author">Author</label>
          <input type="text" id="author" name="author" value={author} />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="pubDate">Publish Date</label>
          <input type="date" id="pubDate" name="pubDate" value={pubDate} />
        </div>
        <div class="form-group">
          <label for="tags">Tags <span style="color:#9CA3AF; font-weight:400;">(comma-separated)</span></label>
          <input type="text" id="tags" name="tags" value={tags} />
        </div>
      </div>

      <div class="form-group">
        <label for="description">Description / Excerpt</label>
        <input type="text" id="description" name="description" value={description} />
      </div>

      <div class="form-group">
        <label for="heroImage">Hero Image</label>
        {heroImage && heroImage.startsWith('/') && (
          <img src={heroImage} alt="Current hero" style="max-height:180px; border-radius:8px; object-fit:cover; margin-bottom:0.5rem;" />
        )}
        <input type="file" id="heroImage" name="heroImage" accept="image/*" onchange="previewImage(this, 'imgPreview')" />
        <img id="imgPreview" src="" alt="Preview" style="display:none; margin-top:0.5rem; max-height:200px; border-radius:8px; object-fit:cover;" />
        <span style="font-size:0.75rem; color:rgba(0,0,0,0.4);">{heroImage ? 'Upload a new image to replace the current one' : 'Accepted: JPG, PNG, WebP, GIF'}</span>
      </div>

      <div class="form-group">
        <label for="content">Content <span style="color:#9CA3AF; font-weight:400;">(Markdown)</span></label>
        <textarea id="content" name="content" rows="20">{content}</textarea>
      </div>

      <div style="display:flex; gap:1rem;">
        <button type="submit" class="btn-admin btn-admin--green">Save Changes</button>
        <a href="/admin/blog" class="btn-admin btn-admin--outline">Cancel</a>
      </div>
    </form>
  </div>
</AdminLayout>

<style>
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
  @media (max-width:640px) { .form-row { grid-template-columns:1fr; } }
  .form-group { display:flex; flex-direction:column; gap:0.4rem; }
  label { font-size:0.8rem; font-weight:600; color:#374151; text-transform:uppercase; letter-spacing:0.04em; }
  input, textarea {
    background:#fff; border:1.5px solid #D1D5DB; border-radius:8px; padding:0.75rem 1rem;
    color:#111827; font-family:inherit; font-size:0.9rem; outline:none;
    transition:border-color 0.15s, box-shadow 0.15s; width:100%;
  }
  textarea { resize:vertical; font-family:'Courier New', monospace; font-size:0.85rem; line-height:1.6; }
  input:focus, textarea:focus { border-color:#22C55E; box-shadow:0 0 0 3px rgba(34,197,94,0.1); }
  input::placeholder, textarea::placeholder { color:#9CA3AF; }
  input[type="file"] {
    background:#fff; border:1.5px dashed #D1D5DB; border-radius:8px; padding:0.6rem 1rem;
    color:#111827; font-family:inherit; font-size:0.875rem; cursor:pointer; width:100%;
  }
  input[type="file"]:hover { border-color:#22C55E; }
</style>

<script>
  function previewImage(input: HTMLInputElement, previewId: string) {
    const preview = document.getElementById(previewId) as HTMLImageElement | null;
    if (!preview) return;
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = (e) => {
        const result = (e.target as FileReader).result as string;
        preview.src = result;
        preview.style.display = 'block';
      };
      reader.readAsDataURL(input.files[0]);
    }
  }
</script>
