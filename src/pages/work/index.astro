---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { sql } from '../../lib/db';

const projects = await sql`SELECT slug, title, client, service, tools, description, results, hero_image, featured FROM projects ORDER BY display_order ASC, created_at DESC`.catch(() => []);
---

<Layout
  title="Our Work — HashTurn Automation Projects"
  description="Browse 200+ automation projects delivered by HashTurn. See real results for real clients across business process automation, RPA, Microsoft 365, and API integrations."
>
  <section class="page-hero">
    <div class="container text-center">
      <p class="section-label">Case Studies</p>
      <h1 style="color:var(--white);">Projects We've Delivered</h1>
      <p style="color:rgba(255,255,255,0.7); max-width:500px; margin:0.75rem auto 0; font-size:1.05rem;">
        Real automation builds for real businesses — with measurable results.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {projects.length === 0 ? (
        <div class="empty-state"><p>No projects yet. Check back soon!</p></div>
      ) : (
        <div class="projects-grid">
          {(projects as any[]).map(project => {
            const tools: string[] = JSON.parse(String(project.tools ?? '[]'));
            const heroImage = String(project.hero_image ?? '');
            return (
              <article class="project-card">
                {heroImage && (
                  <div class="project-card__img">
                    <img src={heroImage} alt={String(project.title)} />
                  </div>
                )}
                <div class="project-card__body">
                  <div class="project-card__meta">
                    <span class="service-tag">{String(project.service)}</span>
                  </div>
                  <h2 class="project-card__title">{String(project.title)}</h2>
                  <p class="project-card__client">Client: {String(project.client)}</p>
                  <p class="project-card__desc">{String(project.description)}</p>
                  {tools.length > 0 && (
                    <div class="project-card__tools">
                      {tools.map(t => <span class="tool-badge">{t}</span>)}
                    </div>
                  )}
                  <div class="project-card__results">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    {String(project.results)}
                  </div>
                  <a href={`/work/${project.slug}/`} class="project-card__link">
                    View case study
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <section class="section section--gray">
    <div class="container text-center">
      <h2 class="section-title">Ready to See Results Like These?</h2>
      <p class="section-sub" style="margin:0 auto 2rem;">
        Book a free 30-minute strategy call and we'll show you exactly how we'd automate your processes.
      </p>
      <a href="/contact" class="btn btn--green btn--lg">
        Book Your Free Call
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  .page-hero { background:var(--black); padding:4rem 1.5rem 5rem; }
  .projects-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2rem; }
  .project-card { background:var(--white); border:1px solid var(--gray-200); border-radius:var(--r); overflow:hidden; display:flex; flex-direction:column; transition:box-shadow 0.2s, transform 0.2s; }
  .project-card:hover { box-shadow:var(--shadow-lg); transform:translateY(-3px); }
  .project-card__img img { width:100%; height:200px; object-fit:cover; display:block; }
  .project-card__body { padding:1.75rem; display:flex; flex-direction:column; flex:1; }
  .project-card__meta { margin-bottom:0.75rem; }
  .service-tag { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:var(--green-dark); background:var(--green-light); padding:0.2rem 0.65rem; border-radius:50px; }
  .project-card__title { font-size:1.1rem; color:var(--gray-900); margin-bottom:0.35rem; line-height:1.3; }
  .project-card__client { font-size:0.82rem; color:var(--gray-400); margin-bottom:0.75rem; }
  .project-card__desc { font-size:0.88rem; color:var(--gray-500); line-height:1.6; margin-bottom:1rem; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
  .project-card__tools { display:flex; flex-wrap:wrap; gap:0.35rem; margin-bottom:1rem; }
  .tool-badge { font-size:0.72rem; font-weight:600; color:#374151; background:#F3F4F6; padding:0.2rem 0.55rem; border-radius:4px; }
  .project-card__results { display:flex; align-items:center; gap:0.4rem; font-size:0.85rem; font-weight:600; color:var(--green-dark); margin-bottom:1.25rem; margin-top:auto; }
  .project-card__results svg { color:var(--green); flex-shrink:0; }
  .project-card__link { display:inline-flex; align-items:center; gap:0.4rem; font-size:0.88rem; font-weight:600; color:var(--green-dark); text-decoration:none; transition:gap 0.15s; }
  .project-card__link:hover { gap:0.65rem; }
  .empty-state { text-align:center; padding:4rem; color:var(--gray-400); font-size:1.1rem; }
  @media (max-width:1024px) { .projects-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:640px) { .projects-grid { grid-template-columns:1fr; } }
</style>
