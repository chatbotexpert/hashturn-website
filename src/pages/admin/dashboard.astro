---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { sql } from '../../lib/db';

let blogCount = 0, projectCount = 0, teamCount = 0, reviewCount = 0, submissionCount = 0, newCount = 0;

try {
  const [b, p, t, r, s, n] = await Promise.all([
    sql`SELECT COUNT(*)::int AS c FROM blog_posts`,
    sql`SELECT COUNT(*)::int AS c FROM projects`,
    sql`SELECT COUNT(*)::int AS c FROM team_members`,
    sql`SELECT COUNT(*)::int AS c FROM reviews`,
    sql`SELECT COUNT(*)::int AS c FROM submissions`,
    sql`SELECT COUNT(*)::int AS c FROM submissions WHERE status='new'`,
  ]);
  blogCount = b[0].c;
  projectCount = p[0].c;
  teamCount = t[0].c;
  reviewCount = r[0].c;
  submissionCount = s[0].c;
  newCount = n[0].c;
} catch (e) {
  console.error('Dashboard DB error:', e);
}
---

<AdminLayout title="Dashboard" activeNav="dashboard">
  <div class="stat-cards">
    <div class="stat-card">
      <div class="stat-card__label">Blog Posts</div>
      <div class="stat-card__value">{blogCount}</div>
      <div class="stat-card__sub"><a href="/admin/blog" style="color:#22C55E;">Manage →</a></div>
    </div>
    <div class="stat-card">
      <div class="stat-card__label">Team Members</div>
      <div class="stat-card__value">{teamCount}</div>
      <div class="stat-card__sub"><a href="/admin/team" style="color:#22C55E;">Manage →</a></div>
    </div>
    <div class="stat-card">
      <div class="stat-card__label">Projects</div>
      <div class="stat-card__value">{projectCount}</div>
      <div class="stat-card__sub"><a href="/admin/projects" style="color:#22C55E;">Manage →</a></div>
    </div>
    <div class="stat-card">
      <div class="stat-card__label">Reviews</div>
      <div class="stat-card__value">{reviewCount}</div>
      <div class="stat-card__sub"><a href="/admin/reviews" style="color:#22C55E;">Manage →</a></div>
    </div>
    <div class="stat-card">
      <div class="stat-card__label">Submissions</div>
      <div class="stat-card__value">{submissionCount}</div>
      <div class="stat-card__sub">
        {newCount > 0
          ? <a href="/admin/submissions" style="color:#22C55E;">{newCount} new →</a>
          : <a href="/admin/submissions" style="color:#22C55E;">View all →</a>}
      </div>
    </div>
  </div>

  <div class="admin-card" style="margin-top:1.5rem;">
    <div class="admin-card__header">
      <span class="admin-card__title">Quick Actions</span>
    </div>
    <div style="padding:1.25rem; display:flex; gap:0.75rem; flex-wrap:wrap;">
      <a href="/admin/blog/new" class="btn-admin btn-admin--green">+ New Blog Post</a>
      <a href="/admin/projects/new" class="btn-admin btn-admin--green">+ New Project</a>
      <a href="/admin/reviews/new" class="btn-admin btn-admin--outline">+ Add Review</a>
      <a href="/admin/team/new" class="btn-admin btn-admin--outline">+ Add Team Member</a>
      {submissionCount === 0 && (
        <div style="padding:0.5rem 1rem; background:#FEF3C7; border:1px solid #FDE68A; border-radius:8px; font-size:0.85rem; color:#92400E;">
          No DB data yet? <strong><a href="#" id="seedBtn" style="color:#92400E;">Seed from existing files →</a></strong>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script>
  document.getElementById('seedBtn')?.addEventListener('click', async (e) => {
    e.preventDefault();
    if (!confirm('This will import existing JSON and markdown files into the database. OK?')) return;
    const btn = e.target as HTMLElement;
    btn.textContent = 'Seeding...';
    try {
      const res = await fetch('/admin/api/seed', { method: 'POST' });
      const json = await res.json();
      if (json.ok) {
        alert('✓ Database seeded successfully! Refresh the page.');
        location.reload();
      } else {
        alert('Errors: ' + JSON.stringify(json.errors));
      }
    } catch {
      alert('Seed failed. Check console.');
    }
  });
</script>
